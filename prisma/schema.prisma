generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --------------------------------------------------------
// ENUMS
// --------------------------------------------------------

enum Role {
  USER
  BUYER
  PRODUCER
  ADMIN
  SUPERADMIN
  AGENT
}

enum ProducerStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
}

enum Unit {
  KG
  TONNE
  LITRE
  BAG
}

enum StockType {
  INPUT
  HARVEST
  EQUIPMENT
}

enum MovementType {
  IN
  OUT
  WASTE
}

enum ExpenseCategory {
  LABOUR
  FUEL
  SEEDS
  FERTILIZER
  TRANSPORT
  OTHER
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  BANK_TRANSFER
}

enum OrderSource {
  APP
  WHATSAPP
  VOICE_CALL
}

enum OrganizationType {
  GOVERNMENT_REGIONAL
  COOPERATIVE
  NGO
  PRIVATE_TRADER
  RESELLER
}

enum OrgRole {
  ADMIN
  ZONE_MANAGER
  SALES_MANAGER
  FIELD_AGENT
}
enum OrgStatus {
  PENDING
  ACTIVE
  SUSPENDED
}


// --------------------------------------------------------
// ORGANISATION & MULTI-TENANCY
// --------------------------------------------------------

model Organization {
  id          String           @id @default(cuid())
  name        String
  type        OrganizationType
  taxId       String?          @unique
  description String?

  users       UserOrganization[]
  zones       Zone[]
  workZones   WorkZone[]
  producers   Producer[]
  stocks      Stock[]
  orders      Order[]
  batches     Batch[]
  status OrgStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organizations")
}

model UserOrganization {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  role   OrgRole @default(FIELD_AGENT)
  roleId String?
  dynRole RoleDef? @relation(fields: [roleId], references: [id])

  managedZoneId String?
  zone          Zone?   @relation("ZoneSupervisor", fields: [managedZoneId], references: [id])

  @@unique([userId, organizationId])
  @@map("user_organizations")
}

model RoleDef {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions String[] 

  userOrgs  UserOrganization[]
  createdAt DateTime           @default(now())

  @@map("role_definitions")
}

// --------------------------------------------------------
// GESTION TERRITORIALE
// --------------------------------------------------------

model ClimaticRegion {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  zones       Zone[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("climatic_regions")
}

model Zone {
  id                String         @id @default(cuid())
  name              String         @unique 
  code              String         @unique 
  climaticRegionId  String
  climaticRegion    ClimaticRegion @relation(fields: [climaticRegionId], references: [id])

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // ── Hiérarchie territoriale ──────────────────────────────────────────────
  // Modèle Materialized Path : path = '/north' | '/north/sector-1' | etc.
  // Requête enfants : WHERE path LIKE '/north/%'
  // Permet : Région > Province > Commune > Secteur
  parentId  String?
  parent    Zone?   @relation("ZoneHierarchy", fields: [parentId], references: [id])
  children  Zone[]  @relation("ZoneHierarchy")
  path      String? // ex: "/bf-centre/kadiogo" — mis à jour à la création/déplacement
  depth     Int     @default(0) // 0 = racine, 1 = province, 2 = commune, …

  latitude  Float?
  longitude Float?

  producers   Producer[]
  orders      Order[]
  users       User[]
  farms       Farm[]
  warehouses  Warehouse[] 
  supervisors UserOrganization[] @relation("ZoneSupervisor")

  externalContexts ExternalContext[]
  conversations    Conversation[]

  territoryEvents TerritoryEvent[]
  anomalies       Anomaly[]
  overlayLayers   OverlayLayer[]
  zoneSettings    ZoneSetting[]
  
  workZones       WorkZone[]
  metrics         ZoneMetric[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([climaticRegionId])
  @@index([organizationId])
  @@index([isActive])
  @@index([parentId])
  @@index([path])
  @@map("zones")
}

model WorkZone {
	id             String       @id @default(cuid())
	organizationId String
	organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

	zoneId String
	zone   Zone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

	managerId String?
	manager   User? @relation(fields: [managerId], references: [id])

	role String?

	createdAt DateTime @default(now())
	updatedAt DateTime @updatedAt

	@@unique([organizationId, zoneId])
	@@index([organizationId])
	@@index([zoneId])
	@@map("work_zones")
}

model ZoneMetric {
  id        String   @id @default(cuid())
  zoneId    String
  zone      Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  
  date      DateTime @default(now())
  metricName String  
  value     Float
  
  createdAt DateTime @default(now())

  @@index([zoneId, date, metricName])
  @@map("zone_metrics")
}

// --------------------------------------------------------
// WAREHOUSING & LOGISTICS
// --------------------------------------------------------

model Warehouse {
  id       String  @id @default(cuid())
  name     String
  type     String
  capacity Float?
  location String?

  zoneId String
  zone   Zone   @relation(fields: [zoneId], references: [id])

  stocks Stock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([zoneId])
  @@map("warehouses")
}

// --------------------------------------------------------
// UTILISATEURS & AUTHENTIFICATION
// --------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?   @unique

  role Role @default(USER)

  organizations UserOrganization[]

  zoneId String?
  zone   Zone?   @relation(fields: [zoneId], references: [id])

  accounts Account[]
  sessions Session[]

  producer Producer?
  orders   Order[] 

  agentActions   AgentAction[]
  agentTelemetry AgentTelemetry[]
  conversations  Conversation[]
  auditLogs      AuditLog[]

  processedEvents   TerritoryEvent[] @relation("UserProcessedEvents")
  resolvedAnomalies Anomaly[]        @relation("UserResolvedAnomalies")

  managedWorkZones WorkZone[]

  // Validation qualité
  verifiedProducts Product[] @relation("ProductVerifier")
  verifiedStocks   Stock[]   @relation("StockVerifier")

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([zoneId])
  @@index([createdAt])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// --------------------------------------------------------
// STRUCTURE AGROBUSINESS
// --------------------------------------------------------

model Client {
  id            String    @id @default(cuid())
  name          String
  phone         String
  email         String?
  location      String?
  totalOrders   Int       @default(0)
  totalSpent    Float     @default(0)
  lastOrderDate DateTime?

  producerId String
  producer   Producer @relation(fields: [producerId], references: [id])
  orders     Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([name])
  @@index([producerId])
  @@map("clients")
}

model Producer {
  id      String @id @default(cuid())
  userId  String @unique
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  businessName String?
  status       ProducerStatus @default(PENDING)
  isCertified  Boolean        @default(false)

  zoneId String?
  zone   Zone?   @relation(fields: [zoneId], references: [id])

  region   String?
  province String?
  commune  String?

  farms    Farm[]
  products Product[]

  clients Client[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([organizationId])
  @@index([zoneId])
  @@map("producers")
}

model Farm {
  id       String  @id @default(cuid())
  name     String
  location String?

  size        Float?
  soilType    String?
  waterSource String?

  zoneId String?
  zone   Zone?   @relation(fields: [zoneId], references: [id])

  producerId String
  producer   Producer @relation(fields: [producerId], references: [id], onDelete: Cascade)

  inventory  Stock[]
  expenses   Expense[]
  cropCycles CropCycle[]
  batches    Batch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([producerId])
  @@index([zoneId])
  @@map("farms")
}

model CropCycle {
  id                  String   @id @default(cuid())
  farmId              String
  farm                Farm     @relation(fields: [farmId], references: [id])
  cropType            String 
  areaSize            Float 
  plantedAt           DateTime
  expectedHarvestDate DateTime
  expectedYield       Float 
  status              String 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([farmId])
  @@map("crop_cycles")
}

// --------------------------------------------------------
// GESTION DE L'INVENTAIRE
// --------------------------------------------------------

model Stock {
  id             String        @id @default(cuid())
  
  farmId         String?
  farm           Farm?         @relation(fields: [farmId], references: [id], onDelete: Cascade)

  warehouseId    String?
  warehouse      Warehouse?    @relation(fields: [warehouseId], references: [id])

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  itemName String
  quantity Float         @default(0)
  unit     Unit          @default(KG)
  type     StockType     @default(HARVEST)

  movements StockMovement[]
  batches   Batch[]

  // ── Validation qualité (agent de terrain) ──────────────────────────────
  verifiedAt     DateTime?
  verifiedById   String?
  verifiedBy     User?     @relation("StockVerifier", fields: [verifiedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([farmId])
  @@index([warehouseId])
  @@index([organizationId])
  @@index([type])
  @@index([verifiedById])
  @@map("stocks")
}

model StockMovement {
  id       String       @id @default(cuid())
  stockId  String
  stock    Stock        @relation(fields: [stockId], references: [id], onDelete: Cascade)

  type     MovementType
  quantity Float
  reason   String?

  createdAt DateTime @default(now())

  @@index([stockId])
  @@index([createdAt])
  @@map("stock_movements")
}

model Batch {
  id             String       @id @default(cuid())
  stockId        String
  stock          Stock        @relation(fields: [stockId], references: [id], onDelete: Cascade)
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  batchNumber    String       @unique
  originFarmId   String?
  farm           Farm?        @relation(fields: [originFarmId], references: [id])
  quantity       Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stockId])
  @@index([organizationId])
  @@map("batches")
}

// --------------------------------------------------------
// SUIVI FINANCIER
// --------------------------------------------------------

model Expense {
  id       String          @id @default(cuid())
  farmId   String
  farm     Farm            @relation(fields: [farmId], references: [id], onDelete: Cascade)

  label    String
  amount   Float
  category ExpenseCategory @default(OTHER)
  date     DateTime        @default(now())

  @@index([farmId])
  @@index([category])
  @@index([date])
  @@map("expenses")
}

// --------------------------------------------------------
// CATALOGUE PUBLIC & VENTES
// --------------------------------------------------------

model Product {
  id              String   @id @default(cuid())
  shortCode       String?  @unique
  name            String   @default("Produit")

  categoryLabel   String
  localNames      Json?    
  description     String?
  price           Float
  unit            Unit     @default(KG)
  quantityForSale Float    @default(0)

  images          String[]
  audioUrl        String?

  producerId String
  producer   Producer @relation(fields: [producerId], references: [id], onDelete: Cascade)

  orderItems OrderItem[]

  // ── Validation qualité (agent de terrain) ──────────────────────────────
  verifiedAt     DateTime?
  verifiedById   String?
  verifiedBy     User?     @relation("ProductVerifier", fields: [verifiedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([producerId])
  @@index([categoryLabel])
  @@index([price])
  @@index([createdAt])
  @@index([verifiedById])
  @@map("products")
}

// --------------------------------------------------------
// SYSTÈME DE COMMANDE
// --------------------------------------------------------

model Order {
  id String @id @default(cuid())

  buyerId String?
  buyer   User?   @relation(fields: [buyerId], references: [id])

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  customerName  String?
  customerPhone String?

  zoneId String?
  zone   Zone?   @relation(fields: [zoneId], references: [id])

  paymentMethod PaymentMethod @default(CASH)
  paymentStatus PaymentStatus @default(PENDING)

  city          String?
  gpsLat        Float?
  gpsLng        Float?
  deliveryDesc  String?

  audioUrl      String?
  status        OrderStatus @default(PENDING)
  source        OrderSource @default(APP)
  whatsappId    String?
  
  totalAmount   Float
  isAgentOrder  Boolean @default(false)

  agentAction   AgentAction? 

  items OrderItem[]

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buyerId])
  @@index([organizationId])
  @@index([status])
  @@index([zoneId])
  @@index([createdAt])
  @@index([customerPhone])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity    Float
  priceAtSale Float

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

enum AgentActionStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED
  FAILED
}

enum ValidationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model AgentAction {
  id           String @id @default(cuid())
  agentName    String 
  actionType   String 
  batchId      String?
  payload      Json

  status       AgentActionStatus  @default(PENDING)
  priority     ValidationPriority @default(MEDIUM)

  orderId      String? @unique
  order        Order?  @relation(fields: [orderId], references: [id])

  userId       String?
  user         User?   @relation(fields: [userId], references: [id])

  auditTrailId String? 
  aiReasoning  String? @db.Text

  adminNotes    String?
  validatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([batchId])
  @@index([agentName])
  @@map("agent_actions")
}

model AgentTelemetry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  latitude  Float
  longitude Float
  battery   Int?    
  signal    String? 
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("agent_telemetry")
}

model ExternalContext {
  id String @id @default(cuid())

  fileName String
  fileType String 
  fileUrl  String

  category String? 
  zoneId   String?
  zone     Zone?   @relation(fields: [zoneId], references: [id])

  isVectorized Boolean @default(false)
  mcpServerId  String? 

  createdAt DateTime @default(now())

  @@map("external_context_files")
}

model Conversation {
  id String @id @default(cuid())

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  query    String @db.Text
  response String? @db.Text

  agentType String? 
  crop      String? 
  zoneId    String?
  zone      Zone?   @relation(fields: [zoneId], references: [id])

  mode      String  @default("text") 
  audioUrl  String? 

  isWaitingForInput Boolean @default(false)
  missingSlots      Json?
  executionPath     Json?
  confidenceScore   Float?
  totalTokensUsed   Int     @default(0)
  responseTimeMs    Int?
  auditTrailId      String? @unique

  anomalyId String?  @unique
  anomaly   Anomaly? @relation(fields: [anomalyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([agentType])
  @@index([createdAt(sort: Desc)])
  @@map("conversations")
}

// --------------------------------------------------------
// GOVERNANCE & AUDIT ("Eye of God")
// --------------------------------------------------------

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String 
  actor      User     @relation(fields: [actorId], references: [id])

  action     String 
  entityId   String 
  entityType String 

  oldValue   Json? 
  newValue   Json? 
  ipAddress  String?

  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entityId])
  @@map("audit_logs")
}

// --------------------------------------------------------
// TERRITORY DYNAMICS
// --------------------------------------------------------

model TerritoryEvent {
  id            String   @id @default(cuid())
  zoneId        String
  zone          Zone     @relation(fields: [zoneId], references: [id])

  eventType     String 
  payload       Json?
  meta          Json?

  status        String   @default("NEW")

  createdAt     DateTime @default(now())
  processedAt   DateTime?
  processedById String?
  processedBy   User?    @relation("UserProcessedEvents", fields: [processedById], references: [id])

  @@index([zoneId])
  @@index([eventType])
  @@map("territory_events")
}

model Anomaly {
  id            String   @id @default(cuid())
  zoneId        String
  zone          Zone     @relation(fields: [zoneId], references: [id])

  source        String? 
  level         String 
  title         String
  message       String?  @db.Text
  details       Json?

  isResolved    Boolean  @default(false)
  resolvedById  String?
  resolvedBy    User?    @relation("UserResolvedAnomalies", fields: [resolvedById], references: [id])
  resolvedAt    DateTime?

  conversation  Conversation? 

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([zoneId])
  @@index([isResolved])
  @@map("anomalies")
}

model OverlayLayer {
  id        String   @id @default(cuid())
  zoneId    String
  zone      Zone     @relation(fields: [zoneId], references: [id])

  key       String 
  label     String
  enabled   Boolean  @default(false)
  settings  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([zoneId, key])
  @@index([zoneId])
  @@map("overlay_layers")
}

model ZoneSetting {
  id        String   @id @default(cuid())
  zoneId    String
  zone      Zone     @relation(fields: [zoneId], references: [id])

  key       String
  value     Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([zoneId, key])
  @@index([zoneId])
  @@map("zone_settings")
}
